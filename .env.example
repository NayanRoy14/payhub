# PayHub environment configuration
# Copy this file to .env and fill in real sandbox/test-mode credentials.
# Never commit .env — it is gitignored.

PORT=3000

# MongoDB (local or Atlas free tier)
MONGODB_URI=mongodb://localhost:27017/payhub

# Redis (for BullMQ retry queue) — local or free-tier hosted Redis
REDIS_URL=redis://localhost:6379

# Razorpay TEST MODE credentials only (https://dashboard.razorpay.com -> Test Mode -> API Keys)
RAZORPAY_KEY_ID=replace-with-your-razorpay-test-key-id
RAZORPAY_KEY_SECRET=replace-with-your-razorpay-test-key-secret
RAZORPAY_WEBHOOK_SECRET=replace-with-your-razorpay-webhook-secret

# Stripe TEST MODE credentials only (https://dashboard.stripe.com -> Test mode -> API keys)
# Not wired into the active routing order (see CASHFREE_* below) — Stripe India
# signup is currently invite-only, so live test credentials aren't obtainable
# from India. StripeAdapter is still implemented and tested; fill these in
# and flip routingEngine's PROCESSOR_ORDER back if you get Stripe access.
STRIPE_SECRET_KEY=replace-with-your-stripe-test-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-your-stripe-webhook-signing-secret

# Cashfree TEST MODE credentials only (https://merchant.cashfree.com -> Developers -> API Keys, Test Mode)
# This is PayHub's active fallback processor in place of Stripe.
CASHFREE_ENV=sandbox
CASHFREE_APP_ID=replace-with-your-cashfree-test-app-id
CASHFREE_SECRET_KEY=replace-with-your-cashfree-test-secret-key
