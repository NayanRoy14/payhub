{
  "name": "payhub",
  "version": "0.1.0",
  "description": "UPI-first payment orchestration layer (portfolio/learning project) sitting in front of Razorpay and Stripe test-mode processors.",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:sdk": "tsc -p tsconfig.sdk.json",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand"
  },
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "bullmq": "^5.12.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.5.1",
    "razorpay": "^2.9.4",
    "stripe": "^16.8.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.4.1",
    "redis-memory-server": "^0.17.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.2.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  },
  "allowScripts": {
    "mongodb-memory-server@9.5.0": true,
    "msgpackr-extract@3.0.4": true,
    "redis-memory-server@0.17.0": true
  }
}
